<?xml version="1.0" encoding="shift_jis" ?>
<configuration>
  <log4net>
    <appender name="ERROR_LOG" type="log4net.Appender.RollingFileAppender">
      <param name="File" value="./log/SWTIC_ErrorLog_"/>
      <param name="AppendToFile" value="true"/>
      <param name="RollingStyle" value="Composite"/>
      <param name="MaxSizeRollBackups" value="30"/>
      <param name="MaximumFileSize" value="2MB"/>
      <param name="StaticLogFileName" value="false"/>
      <param name="DatePattern" value="yyyyMMdd&quot;.log&quot;"/>
      <layout type="log4net.Layout.PatternLayout">
        <header value="Date       Time     Error Code               Error Message&#xA;"/>
        <conversionPattern value="%date{yyyy/MM/dd HH:mm:ss} %message%newline"/>
      </layout>
      <lockingModel type="log4net.Appender.FileAppender+MinimalLock"/>
    </appender>
    <appender name="TRACE_LOG" type="log4net.Appender.RollingFileAppender">
      <param name="File" value="./log/SWTIC_TraceLog_"/>
      <param name="AppendToFile" value="true"/>
      <param name="RollingStyle" value="Composite"/>
      <param name="MaxSizeRollBackups" value="30"/>
      <param name="MaximumFileSize" value="2MB"/>
      <param name="StaticLogFileName" value="false"/>
      <param name="DatePattern" value="yyyyMMdd&quot;.log&quot;"/>
      <layout type="log4net.Layout.PatternLayout">
        <header value="Date       Time     Trace Message&#xA;"/>
        <conversionPattern value="%date{yyyy/MM/dd HH:mm:ss} %message%newline"/>
      </layout>
      <lockingModel type="log4net.Appender.FileAppender+MinimalLock"/>
    </appender>
    <appender name="DEBUG_LOG" type="log4net.Appender.RollingFileAppender">
      <param name="File" value="./log/SWTIC_DebugLog_"/>
      <param name="AppendToFile" value="true"/>
      <param name="RollingStyle" value="Composite"/>
      <param name="MaxSizeRollBackups" value="30"/>
      <param name="MaximumFileSize" value="2MB"/>
      <param name="StaticLogFileName" value="false"/>
      <param name="DatePattern" value="yyyyMMdd&quot;.log&quot;"/>
      <layout type="log4net.Layout.PatternLayout">
        <header value="Date       Time     Information&#xA;"/>
        <conversionPattern value="%date{yyyy/MM/dd HH:mm:ss} %message%newline"/>
      </layout>
      <lockingModel type="log4net.Appender.FileAppender+MinimalLock"/>
    </appender>
    <appender name="EventLogAppender" type="log4net.Appender.EventLogAppender" >
      <applicationName value="RebuildMedia" />
      <layout type="log4net.Layout.PatternLayout">
        <conversionPattern value="[DateTime]:%date{yyyy/MM/dd HH:mm:ss} [ThreadID]:%thread [ErrorLevel]:%-5p %newline%message%newline" />
      </layout>
    </appender>
    <!-- level: ALL < DEBUG < INFO < WARN < ERROR < FATAL -->
    <logger name="ErrorLog">
      <level value="DEBUG"/>
      <appender-ref ref="EventLogAppender"/>
    </logger>
    <!-- logger name="TraceLog">
      <level value="DEBUG"/>
      <appender-ref ref="TRACE_LOG"/>
    </logger -->
    <!-- logger name="DebugLog">
      <level value="DEBUG"/>
      <appender-ref ref="DEBUG_LOG"/>
    </logger -->
  </log4net>

</configuration>
